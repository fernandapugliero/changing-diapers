  <style>
    body {
      font-family: 'Inter', sans-serif;
      margin: 0;
      padding: 2rem;
      background: #fff;
      color: #333;
    }

    .page {
      max-width: 1200px;
      margin: 0 auto;
    }

    nav {
      margin-bottom: 2rem;
      padding-top: 1rem;
      display: flex;
      align-items: center;
    }

    nav img {
      width: 30px;
      height: auto;
      margin-right: 30px;
    }

    nav a {
      margin-right: 20px;
      text-decoration: none;
      font-weight: 600;
      color: inherit;
    }

    .hero {
      padding: 5rem 0 4rem 0;
      max-width: 960px;
    }

    .eyebrow {
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #777;
      margin-bottom: 1rem;
    }

    h1 {
      font-size: clamp(2.6rem, 7vw, 5.8rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
      margin: 0;
      max-width: 900px;
      color: #222;
    }

    .hero p {
      max-width: 680px;
      font-size: 1.08rem;
      line-height: 1.65;
      color: #555;
      margin: 1.6rem 0 0 0;
    }

    .text-link {
      display: inline-block;
      margin-top: 1.5rem;
      color: #222;
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid #222;
      padding-bottom: 3px;
    }

    .section {
      margin-top: 5rem;
    }

    .section-header {
      max-width: 760px;
      margin-bottom: 1.8rem;
    }

    .section-title {
      font-size: clamp(1.7rem, 3vw, 2.6rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
      color: #222;
      margin: 0 0 0.8rem 0;
    }

    .section-subtitle {
      font-size: 1rem;
      color: #666;
      line-height: 1.6;
      margin: 0;
    }

    .founder-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      align-items: center;
    }

    @media (min-width: 820px) {
      .founder-grid {
        grid-template-columns: 0.9fr 1.1fr;
        gap: 3rem;
      }
    }

    .founder-photo {
      background: #f4f4f4;
      border: 1px solid #eee;
      border-radius: 22px;
      overflow: hidden;
      min-height: 420px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #999;
      font-size: 0.9rem;
      text-align: center;
    }

    .founder-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(100%);
    }

    .founder-copy {
      max-width: 640px;
    }

    .founder-copy h2 {
      font-size: clamp(1.9rem, 4vw, 3.5rem);
      line-height: 1.02;
      letter-spacing: -0.05em;
      color: #222;
      margin: 0 0 1rem 0;
    }

    .founder-copy p,
    .text-block p {
      color: #555;
      line-height: 1.7;
      font-size: 1rem;
      margin: 0 0 1rem 0;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    @media (min-width: 760px) {
      .grid-2 {
        grid-template-columns: repeat(2, 1fr);
      }

      .grid-3 {
        grid-template-columns: repeat(3, 1fr);
      }

      .grid-4 {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .card {
      border: 1px solid #eee;
      border-radius: 20px;
      padding: 1.25rem;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .card.large {
      min-height: 190px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .card h3 {
      font-size: 1.05rem;
      color: #222;
      margin: 0 0 0.5rem 0;
      letter-spacing: -0.01em;
    }

    .card p {
      color: #666;
      font-size: 0.92rem;
      line-height: 1.55;
      margin: 0;
    }

    .metric strong {
      display: block;
      font-size: 1.05rem;
      color: #222;
      margin-bottom: 0.35rem;
    }

    .metric span {
      display: block;
      color: #666;
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .process {
      counter-reset: step;
    }

    .process .card {
      position: relative;
    }

    .process .card::before {
      counter-increment: step;
      content: "0" counter(step);
      display: block;
      color: #aaa;
      font-weight: 700;
      font-size: 0.8rem;
      margin-bottom: 2rem;
      letter-spacing: 0.08em;
    }

    .success-story {
      border: 1px solid #eee;
      border-radius: 26px;
      background: #fafafa;
      padding: 1rem;
    }

    @media (min-width: 820px) {
      .success-story {
        padding: 1.4rem;
      }
    }

    .success-top {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    @media (min-width: 820px) {
      .success-top {
        grid-template-columns: 1.1fr 0.9fr;
        gap: 1rem;
      }
    }

    .success-title-card {
      background: #fff;
      border: 1px solid #eee;
      border-radius: 22px;
      padding: 1.25rem;
    }

    .success-title-card h3 {
      font-size: clamp(1.6rem, 4vw, 3rem);
      letter-spacing: -0.05em;
      line-height: 1.05;
      margin: 0 0 1rem 0;
      color: #222;
    }

    .success-title-card p {
      font-size: 0.98rem;
      color: #666;
      line-height: 1.6;
      margin: 0;
    }

    .screenshot-placeholder {
      border: 1px dashed #ccc;
      border-radius: 22px;
      background: #fff;
      min-height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      font-size: 0.9rem;
      text-align: center;
      padding: 1rem;
    }

    .story-details {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    @media (min-width: 760px) {
      .story-details {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .story-details .card {
      box-shadow: none;
    }

    .contact-box {
      max-width: 780px;
      border: 1px solid #eee;
      border-radius: 26px;
      background: #fafafa;
      padding: 1.4rem;
    }

    .contact-box h2 {
      font-size: clamp(2rem, 5vw, 4rem);
      letter-spacing: -0.06em;
      line-height: 1;
      color: #222;
      margin: 0 0 1rem 0;
    }

    .contact-box p {
      color: #555;
      line-height: 1.65;
      font-size: 1rem;
      margin: 0 0 1.3rem 0;
      max-width: 620px;
    }

    .contact-button {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 999px;
      background: #222;
      color: #fff;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
    }

    footer {
