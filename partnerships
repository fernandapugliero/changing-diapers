      font-size: 0.9rem;
      color: #777;
    }

    footer a {
      color: #0070f3;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      body {
        padding: 2rem;
      }

